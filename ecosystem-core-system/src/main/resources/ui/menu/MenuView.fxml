<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.yat.ecosystemcore.ui.menu.MenuController">
   <top>
      <MenuBar fx:id="menuBar" BorderPane.alignment="CENTER">
        </MenuBar>
   </top>
   <center>
      <StackPane fx:id="conteudoCentral" prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Bem-vindo ao YAT Ecosystem Core! Selecione um menu acima." style="-fx-font-size: 16px; -fx-text-fill: #666;" />
         </children>
      </StackPane>
   </center>
   <bottom>
      <HBox spacing="10" style="-fx-padding: 5; -fx-background-color: #eee;">
         <children>
            <Label fx:id="lblUsuarioLogado" text="Usuário: Administrador" />
         </children>
      </HBox>
   </bottom>
</BorderPane>