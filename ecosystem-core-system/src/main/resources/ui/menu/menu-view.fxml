<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="br.com.yat.ecosystemcore.ui.menu.MenuController"
            style="-fx-background-color: #F8F9FA;">
   
   <top>
      <MenuBar fx:id="menuBar" BorderPane.alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);" />
   </top>
   
   <center>
      <StackPane fx:id="conteudoCentral" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label text="Bem-vindo ao YAT Ecosystem Core! Selecione um menu acima." style="-fx-font-size: 16px; -fx-text-fill: #6C757D; -fx-font-weight: bold;" />
         </children>
      </StackPane>
   </center>
   
   <right>
      <VBox alignment="TOP_CENTER" prefWidth="240.0" spacing="20.0" BorderPane.alignment="CENTER"
            style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 0 0 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), -5, 0, 0, 0);">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
         </padding>
         <children>
            
            <VBox spacing="5.0" prefWidth="200.0">
               <children>
                  <Label text="EMPRESA / FILIAL ATIVA" style="-fx-font-size: 10px; -fx-text-fill: #ADB5BD; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                  <ComboBox fx:id="cbSeletorEmpresa" prefHeight="35.0" prefWidth="200.0" promptText="Selecione a Empresa" style="-fx-background-radius: 6; -fx-border-color: #CED4DA; -fx-border-radius: 6; -fx-background-color: #FFFFFF;" />
               </children>
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </VBox>
            
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="TEMPO DE ACESSO" style="-fx-font-size: 10px; -fx-text-fill: #ADB5BD; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                  <Label fx:id="lblTempoAcesso" text="00:00:00" style="-fx-font-size: 14px; -fx-text-fill: #495057; -fx-font-weight: bold;" />
               </children>
            </VBox>
            
            <VBox alignment="CENTER" spacing="8.0" style="-fx-background-color: #F8F9FA; -fx-background-radius: 8; -fx-padding: 15;">
               <children>
                  <ImageView fx:id="imgUsuario" fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="true" />
                  <Label fx:id="lblUsuarioLogado" text="Administrador" textAlignment="CENTER" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #212529; -fx-font-weight: bold;" />
               </children>
            </VBox>
            
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 5 0 5 0;">
               <children>
                  <ImageView fx:id="imgData" fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true" />
                  <Label fx:id="lblHora" text="--/--/---- --:--" style="-fx-font-size: 13px; -fx-text-fill: #495057;" />
               </children>
            </HBox>
            
            <VBox VBox.vgrow="ALWAYS" />
            
            <ImageView fx:id="imgLogo" fitHeight="80.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </VBox>
   </right>
   
   <bottom>
      <HBox alignment="CENTER_LEFT" prefHeight="30.0" spacing="15.0" BorderPane.alignment="CENTER"
            style="-fx-background-color: #F1F3F5; -fx-padding: 5 15 5 15; -fx-border-color: #E9ECEF; -fx-border-width: 1 0 0 0;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="8.0" prefWidth="200.0">
               <children>
                  <ImageView fx:id="imgStatusBanco" fitHeight="14.0" fitWidth="14.0" pickOnBounds="true" preserveRatio="true" />
                  <Label fx:id="lblStatusBanco" text="CONECTANDO..." style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #6C757D;" />
               </children>
            </HBox>
            
            <Label HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" alignment="CENTER" 
                   text="SISTEMA DESENVOLVIDO POR YURE ARAUJO TORRES - VERSÃO 1.0.0" 
                   style="-fx-font-size: 11px; -fx-text-fill: #868E96; -fx-font-weight: bold;" />
                   
            <Label prefWidth="200.0" />
         </children>
      </HBox>
   </bottom>
</BorderPane>