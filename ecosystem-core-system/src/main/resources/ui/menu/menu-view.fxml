<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootContainer" xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.com.yat.ecosystemcore.ui.menu.MenuController">

    <BorderPane fx:id="rootPane" prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #F8F9FA;">

        <top>
            <VBox>
                <ToolBar style="-fx-background-color: white; -fx-padding: 10; -fx-border-color: #E9ECEF; -fx-border-width: 0 0 1 0;">
                    <Button text="🏠 Home" style="-fx-background-radius: 8; -fx-padding: 6 14; -fx-background-color: transparent;"/>
                    <Button text="🔄 Refresh" style="-fx-background-radius: 6; -fx-padding: 6 12;"/>
                    <Separator orientation="VERTICAL"/>
                    <Button text="⌘K Command" onAction="#openCommandPalette" style="-fx-background-color: #4C6EF5; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 14;"/>
                    <Separator orientation="VERTICAL"/>
                    <Button text="⛔ Logout" onAction="#onLogout" style="-fx-background-color: #DC3545; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 14;"/>
                </ToolBar>
                <MenuBar fx:id="menuBar" style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);"/>
            </VBox>
        </top>

        <center>
            <VBox>
                <HBox fx:id="breadcrumbBar" spacing="6" style="-fx-padding: 6; -fx-background-color: #F1F3F5;"/>
                <StackPane fx:id="conteudoCentral">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <Label text="Bem-vindo ao sistema" style="-fx-font-size: 16px; -fx-text-fill: #6C757D;"/>
                </StackPane>
            </VBox>
        </center>

        <right>
            <VBox spacing="16" prefWidth="260" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 0 0 1;">
                <padding>
                    <Insets top="20" right="16" bottom="20" left="16"/>
                </padding>
                <VBox spacing="6" style="-fx-background-color: #F8F9FA; -fx-background-radius: 10; -fx-padding: 10;">
                    <Label text="EMPRESA ATIVA"/>
                    <ComboBox fx:id="cbSeletorEmpresa" prefHeight="34"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="TEMPO DE SESSÃO"/>
                    <Label fx:id="lblTempoAcesso" text="00:00:00"/>
                </VBox>
                <VBox alignment="CENTER" spacing="8" style="-fx-background-color: #F8F9FA; -fx-background-radius: 10; -fx-padding: 12;">
                    <ImageView fx:id="imgUsuario" fitHeight="56" fitWidth="56" preserveRatio="true"/>
                    <Label fx:id="lblUsuarioLogado" text="Usuário"/>
                </VBox>
                <HBox spacing="8">
                    <ImageView fx:id="imgData" fitHeight="18" fitWidth="18"/>
                    <Label fx:id="lblHora" text="--/--/---- --:--"/>
                </HBox>
                <VBox VBox.vgrow="ALWAYS"/>
                <ImageView fx:id="imgLogo" fitWidth="180" fitHeight="70" preserveRatio="true"/>
            </VBox>
        </right>

        <bottom>
            <HBox spacing="12" style="-fx-background-color: #F1F3F5; -fx-padding: 6; -fx-border-color: #E9ECEF; -fx-border-width: 1 0 0 0;">
                <HBox spacing="6">
                    <ImageView fx:id="imgStatusBanco" fitHeight="14" fitWidth="14"/>
                    <Label fx:id="lblStatusBanco" text="OK"/>
                </HBox>
                <Label text="YAT ECOSYSTEM CORE" HBox.hgrow="ALWAYS"/>
            </HBox>
        </bottom>
    </BorderPane>

    <StackPane fx:id="commandPaletteOverlay"
               visible="false"
               managed="false"
               pickOnBounds="true"
               alignment="CENTER"
               style="-fx-background-color: rgba(0,0,0,0.6);">

        <VBox alignment="CENTER"
              maxWidth="520" 
              maxHeight="400"
              spacing="10"
              style="-fx-background-color: #1E1E1E;
                     -fx-padding: 16;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, black, 20, 0.4, 0, 10);">

            <TextField fx:id="txtCommandSearch"
                       promptText="Search command..."
                       style="-fx-background-color: #2D2D2D;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #888;
                              -fx-background-radius: 6;
                              -fx-padding: 10;
                              -fx-border-color: #444;
                              -fx-border-radius: 6;"
                       onKeyPressed="#onCommandKey"/>

            <ListView fx:id="lstCommands"
                      prefHeight="300"
                      style="-fx-background-color: transparent;
                             -fx-control-inner-background: #1E1E1E;
                             -fx-text-fill: white;
                             -fx-background-radius: 6;"/>
        </VBox>
    </StackPane>

</StackPane>