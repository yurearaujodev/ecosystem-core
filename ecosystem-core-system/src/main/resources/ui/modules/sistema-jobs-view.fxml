<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="br.com.yat.ecosystemcore.ui.modules.system.SistemaJobsController"
      spacing="10" prefWidth="850" prefHeight="550" style="-fx-background-color: #f4f6f9;">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <VBox>
            <Label text="⏳ Agendamentos e Background Jobs" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Histórico de execuções da tabela 'job_execucao'" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Atualizar Logs" onAction="#carregarDados" style="-fx-cursor: hand;"/>
    </HBox>
    <Separator/>
    <TableView fx:id="tblJobs" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colTipo" text="Rotina / Tipo de Job" prefWidth="220"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
            <TableColumn fx:id="colInicio" text="Data/Hora Início" prefWidth="150"/>
            <TableColumn fx:id="colFim" text="Data/Hora Fim" prefWidth="150"/>
            <TableColumn fx:id="colErro" text="Mensagem de Erro" prefWidth="130"/>
        </columns>
    </TableView>
</VBox>