<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" stylesheets="@global.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.yat.ecosystemcore.modules.autorizacao.ui.PermissaoConsultaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <VBox spacing="2.0">
        <Label text="Matriz de Permissões por Perfil" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
        <Label text="Selecione um perfil à esquerda para gerenciar seus respectivos privilégios de acesso aos módulos." style="-fx-font-size: 11px; -fx-text-fill: #6c757d;" />
    </VBox>

    <Separator />

    <SplitPane dividerPositions="0.35" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        
        <VBox spacing="10.0">
            <padding>
                <Insets right="10.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Perfis de Usuário" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button fx:id="btnAtualizarPerfis" text="🔄" onAction="#carregarPerfis">
                    <tooltip>
                        <Tooltip text="Atualizar Perfis" />
                    </tooltip>
                </Button>
            </HBox>
            <TableView fx:id="tblPerfis" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colPerfilNome" prefWidth="180.0" text="Nome do Perfil" />
                    <TableColumn fx:id="colPerfilChave" prefWidth="120.0" text="Chave" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>

        <VBox spacing="10.0">
            <padding>
                <Insets left="10.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label fx:id="lblPerfilSelecionado" text="Selecione um perfil para editar..." style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1A73E8;" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button fx:id="btnSalvar" text="💾 Salvar Alterações" onAction="#onSalvar" disable="true"
                        style="-fx-background-color: #1A73E8; -fx-text-fill: white; -fx-font-weight: bold;" prefHeight="30.0" />
            </HBox>
            
            <TreeView fx:id="treePermissoes" VBox.vgrow="ALWAYS" disable="true"/>
        </VBox>
        
    </SplitPane>
</VBox>