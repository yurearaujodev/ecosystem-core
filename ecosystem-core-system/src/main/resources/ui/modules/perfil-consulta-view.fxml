<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" stylesheets="@global.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.yat.ecosystemcore.modules.seguranca.ui.PerfilConsultaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <VBox spacing="2.0">
            <Label text="Gerenciamento de Perfis (RBAC)" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label text="De um duplo clique em uma linha para editar ou remover o perfil." style="-fx-font-size: 11px; -fx-text-fill: #6c757d;" />
        </VBox>
        <Pane HBox.hgrow="ALWAYS" />
        <Button fx:id="btnNovo" text="➕ Novo Perfil" onAction="#onNovoPerfil" style="-fx-background-color: #2B8A3E; -fx-text-fill: white; -fx-font-weight: bold;" prefHeight="35.0" />
    </HBox>

    <Separator />

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Buscar:" style="-fx-font-weight: bold;" />
        <TextField fx:id="txtPesquisa" promptText="Digite o nome ou a chave para filtrar na tabela..." HBox.hgrow="ALWAYS" prefHeight="32.0" />
        <Button fx:id="btnAtualizar" text="🔄 Atualizar" onAction="#carregarDados" prefHeight="32.0" style="-fx-font-weight: bold;" />
    </HBox>

    <TableView fx:id="tblPerfis" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />
            <TableColumn fx:id="colNome" prefWidth="220.0" text="Nome do Perfil" />
            <TableColumn fx:id="colChave" prefWidth="150.0" text="Chave (Código)" />
            <TableColumn fx:id="colDescricao" prefWidth="350.0" text="Descrição" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>