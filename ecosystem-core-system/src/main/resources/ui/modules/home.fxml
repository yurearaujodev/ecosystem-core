<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="600.0" prefWidth="800.0" 
           xmlns="http://javafx.com/javafx/21" 
           xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="br.com.yat.ecosystemcore.modules.home.ui.HomeController"
           style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 5, 0, 0);">
   
   <children>
      <VBox alignment="CENTER" spacing="15.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <Label text="🏠" style="-fx-font-size: 48px;" />
            
            <Label text="Área de Trabalho Principal" 
                   style="-fx-font-size: 24px; -fx-text-fill: #212529; -fx-font-weight: bold;" />
            
            <Label text="O ecossistema foi inicializado com sucesso. Suas permissões e módulos estão prontos." 
                   style="-fx-font-size: 14px; -fx-text-fill: #6C757D;" textAlignment="CENTER" wrapText="true" />
            
            <VBox maxHeight="1.0" minHeight="1.0" prefHeight="1.0" prefWidth="200.0" 
                  style="-fx-background-color: #E9ECEF;" maxWidth="300.0">
               <VBox.margin>
                  <Insets bottom="10.0" top="10.0" />
               </VBox.margin>
            </VBox>
            
            <Label fx:id="lblMensagemHome" text="Carregando dados da sessão corporativa..." 
                   style="-fx-font-size: 13px; -fx-text-fill: #0D6EFD; -fx-font-weight: bold; -fx-background-color: #E7F1FF; -fx-padding: 8 15 8 15; -fx-background-radius: 5;" 
                   textAlignment="CENTER" wrapText="true" />
         </children>
      </VBox>
   </children>
</StackPane>