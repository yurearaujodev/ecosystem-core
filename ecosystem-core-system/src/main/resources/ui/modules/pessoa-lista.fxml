<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="15.0" stylesheets="@global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.yat.ecosystemcore.modules.cadastro.ui.PessoaListaController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="200.0">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Gerenciamento de Pessoas" textFill="#2c3e50">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>
                  <Label text="Clientes, Fornecedores, Colaboradores e Usuários" textFill="#7f8c8d" />
               </children>
            </VBox>
            <Button mnemonicParsing="false" onAction="#onNovo" styleClass="btn-primary" text="+ Nova Pessoa" />
         </children>
      </HBox>
      
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <TextField fx:id="txtPesquisa" promptText="Pesquisar por Nome, Razão Social ou CPF/CNPJ..." HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#onPesquisar" styleClass="btn-secondary" text="Filtrar" />
         </children>
      </HBox>
      
      <TableView fx:id="tblPessoas" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
          <TableColumn fx:id="colTipo" prefWidth="100.0" text="Tipo" />
            <TableColumn fx:id="colNome" prefWidth="250.0" text="Nome / Razão Social" />
            <TableColumn fx:id="colCpfCnpj" prefWidth="150.0" text="CPF / CNPJ" />
            <TableColumn fx:id="colTelefone" prefWidth="130.0" text="Telefone" />
            <TableColumn fx:id="colStatus" prefWidth="90.0" text="Status" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onExcluir" styleClass="btn-danger" text="Excluir Lógico" />
            <Button mnemonicParsing="false" onAction="#onAlterar" styleClass="btn-warning" text="Alterar Registro" />
         </children>
      </HBox>
   </children>
</VBox>