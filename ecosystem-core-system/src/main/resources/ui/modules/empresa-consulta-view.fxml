<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.yat.ecosystemcore.ui.modules.empresa.EmpresaConsultaController">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
   <children>
      
      <VBox spacing="5.0">
         <children>
            <Label text="Cadastro de Empresas (Filiais)" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
            <Label text="Gerencie as unidades de negócio e filiais vinculadas à conta do seu ecossistema corporativo." style="-fx-font-size: 13px; -fx-text-fill: #6C757D;" />
         </children>
      </VBox>
      
      <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 5, 0, 0, 1);">
         <children>
            <TextField fx:id="txtPesquisa" promptText="🔍 Buscar por Razão Social ou CNPJ..." prefHeight="38.0" prefWidth="350.0" style="-fx-background-radius: 5; -fx-border-color: #CED4DA; -fx-border-radius: 5;" />
            
            <HBox HBox.hgrow="ALWAYS" />
            
            <Button fx:id="btnNovaEmpresa" mnemonicParsing="false" onAction="#onNovaEmpresa" prefHeight="38.0" style="-fx-background-color: #0D6EFD; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="➕ Nova Empresa" />
         </children>
      </HBox>
      
      <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 5, 0, 0, 1);">
         <children>
            <TableView fx:id="tblEmpresas" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-base: transparent;">
              <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colCnpj" prefWidth="140.0" text="CNPJ" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colRazaoSocial" prefWidth="250.0" text="Razão Social" />
                <TableColumn fx:id="colNomeFantasia" prefWidth="200.0" text="Nome Fantasia" />
                <TableColumn fx:id="colCidade" prefWidth="120.0" text="Cidade/UF" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAcoes" prefWidth="100.0" text="Ações" style="-fx-alignment: CENTER;" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
      
   </children>
</VBox>